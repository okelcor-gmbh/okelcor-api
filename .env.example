APP_NAME="Okelcor API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.okelcor.com
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=your_database_name
DB_USERNAME=your_database_user
DB_PASSWORD=your_database_password

CACHE_STORE=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=support@okelcor.com
MAIL_FROM_NAME="Okelcor"

FRONTEND_URL=https://okelcor.com
SANCTUM_STATEFUL_DOMAINS=okelcor.com,www.okelcor.com,okelcor-website.vercel.app
SANCTUM_TOKEN_EXPIRATION=1440
FILESYSTEM_DISK=public

# Active payment gateway: Stripe Checkout
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_CURRENCY=eur

# Legacy/inactive payment gateway: Adyen
# Keep placeholders only until business account/API credentials are approved.
ADYEN_API_KEY=legacy_inactive_adyen_api_key
ADYEN_MERCHANT_ACCOUNT=legacy_inactive_adyen_merchant_account
ADYEN_ENVIRONMENT=test
ADYEN_CLIENT_KEY=legacy_inactive_adyen_client_key

# Legacy/inactive payment gateway: Mollie
# Public Mollie webhook route currently returns HTTP 410.
MOLLIE_WEBHOOK_SECRET=legacy_inactive_mollie_webhook_secret

SHIPSGO_API_KEY=your_shipsgo_api_key
DHL_API_KEY=your_dhl_api_key

ORDER_EMAIL=support@okelcor.com
QUOTE_EMAIL=support@okelcor.com
CONTACT_EMAIL=support@okelcor.com

EBAY_CLIENT_ID=your_ebay_client_id
EBAY_CLIENT_SECRET=your_ebay_client_secret
# EBAY_REFRESH_TOKEN is a legacy fallback only.
# Tokens are now stored encrypted in the ebay_tokens DB table via the OAuth flow.
# Only set this if the DB table is empty and you need a one-time bootstrap.
EBAY_REFRESH_TOKEN=
EBAY_RU_NAME=your_ebay_ru_name
EBAY_MARKETPLACE_ID=EBAY_DE
EBAY_CATEGORY_ID=11755
EBAY_FULFILLMENT_POLICY_ID=your_ebay_fulfillment_policy_id
EBAY_PAYMENT_POLICY_ID=your_ebay_payment_policy_id
EBAY_RETURN_POLICY_ID=your_ebay_return_policy_id
EBAY_SELLER_POSTAL_CODE=your_postal_code
EBAY_SELLER_LOCATION=Germany
EBAY_ENVIRONMENT=sandbox

# Admin 2FA enforcement (set to true to block admin users without 2FA)
ADMIN_2FA_ENFORCED=false
ADMIN_2FA_GRACE_UNTIL=

# Backup configuration
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=1
BACKUP_DISK=local
# Keep product images out of daily backups (they are several GB).
# Set true only if disk quota allows, or run: php artisan backup:okelcor --full
BACKUP_INCLUDE_PRODUCT_IMAGES=false
# MYSQLDUMP_PATH=/usr/bin/mysqldump

# PDF document branding
DOCUMENT_QR_ENABLED=true
DOCUMENT_LOGO_PATH=okelcor-logo.avif
